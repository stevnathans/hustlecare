generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                 @id @default(uuid())
  name               String
  email              String                 @unique
  password           String?
  role               String                 @default("user")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  emailVerified      DateTime?
  image              String?
  phone              String?
  emailNotifications Boolean                @default(true)
  marketingEmails    Boolean                @default(true)
  pushNotifications  Boolean                @default(false)
  isActive           Boolean                @default(true)
  lastLoginAt        DateTime?
  isVerified         Boolean                @default(false)
  verifiedAt         DateTime?
  accounts           Account[]
  auditLogs          AuditLog[]
  businesses         Business[]
  copiedBusinesses   BusinessCopyActivity[]
  carts              Cart[]
  comments           Comment[]
  reviews            Review[]
  searches           SearchLog[]
  sessions           Session[]
  sharedBusinesses   SharedBusiness[]
  requirementSuggestions  RequirementSuggestion[]
  vendorProfile           Vendor?
  vendorApplication       VendorApplication?

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cart {
  id         String     @id @default(uuid())
  userId     String
  businessId Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  name       String?
  totalCost  Float?
  business   Business   @relation(fields: [businessId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model CartItem {
  id              String   @id @default(uuid())
  productId       Int
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  cartId          String
  unitPrice       Float
  updatedAt       DateTime @updatedAt
  category        String?  @default("Uncategorized")
  requirementName String?  @default("Unspecified Requirement")
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

model Business {
  id               Int                   @id @default(autoincrement())
  name             String
  description      String?
  image            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  slug             String                @unique
  userId           String?
  published        Boolean               @default(true)
  categoryId       Int?
  bestLocations    String[]
  costMax          Int?
  costMin          Int?
  profitPotential  String?
  skillLevel       String?
  timeToLaunchMax  Int?
  timeToLaunchMin  Int?
  category         BusinessCategory?     @relation(fields: [categoryId], references: [id])
  user             User?                 @relation(fields: [userId], references: [id])
  faqs             BusinessFaq[]
  requirements     BusinessRequirement[]
  carts            Cart[]
  searches         SearchLog[]
  sharedBusinesses SharedBusiness[]

  @@index([name])
  @@index([slug])
  @@index([published])
}

model BusinessFaq {
  id           Int      @id @default(autoincrement())
  businessId   Int
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([isActive])
}

model BusinessCategory {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  slug       String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]

  @@index([name])
  @@index([slug])
}

model RequirementTemplate {
  id           Int                   @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  category     String
  necessity    String
  isDeprecated Boolean               @default(false)
  deprecatedAt DateTime?
  isGlobal     Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  businesses   BusinessRequirement[]
  products     Product[]

  @@index([category])
  @@index([necessity])
  @@index([isDeprecated])
  @@index([name])
}

model BusinessRequirement {
  id                  Int                 @id @default(autoincrement())
  businessId          Int
  templateId          Int
  descriptionOverride String?
  necessityOverride   String?             // null = inherit from template
  isActive            Boolean             @default(true)
  displayOrder        Int                 @default(0)
  source              String              @default("admin")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  business            Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template            RequirementTemplate @relation(fields: [templateId], references: [id])
  comments            Comment[]

  @@unique([businessId, templateId])
  @@index([businessId])
  @@index([templateId])
  @@index([isActive])
}

model Comment {
  id                    Int                 @id @default(autoincrement())
  content               String
  userId                String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  isApproved            Boolean             @default(false)
  businessRequirementId Int
  businessRequirement   BusinessRequirement @relation(fields: [businessRequirementId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessRequirementId])
  @@index([userId])
  @@index([isApproved])
}

model Product {
  id            Int                   @id @default(autoincrement())
  name          String
  description   String?
  price         Float?
  image         String?
  url           String?

  // ── Ownership ─────────────────────────────────────────────
  vendorId      Int?

  // ── Requirement linking ───────────────────────────────────
  // A product is listed under ONE requirement template.
  // This is how it appears in the marketplace filtered by requirement.
  templateId    Int?

  // ── Marketplace discovery ─────────────────────────────────
  // Denormalised business tags so marketplace queries stay fast.
  // Populated from the BusinessRequirement links of the templateId,
  // but vendors can also explicitly tag additional businesses.
  businessTags  Int[]                 // array of Business.id

  // ── Moderation ────────────────────────────────────────────
  status        ProductStatus         @default(PENDING_REVIEW)
  rejectedAt    DateTime?
  rejectReason  String?
  publishedAt   DateTime?

  // ── Product details ───────────────────────────────────────
  sku           String?               // vendor's own SKU
  stock         Int?                  // null = unlimited / not tracked
  priceMin      Float?                // for products with price ranges
  priceMax      Float?
  currency      String?               @default("KES")

  // ── Metadata ──────────────────────────────────────────────
  isFeatured    Boolean               @default(false)
  featuredAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // ── Relations ─────────────────────────────────────────────
  vendor        Vendor?               @relation(fields: [vendorId], references: [id])
  template      RequirementTemplate?  @relation(fields: [templateId], references: [id])
  cartItems     CartItem[]
  reviews       Review[]

  @@index([vendorId])
  @@index([templateId])
  @@index([status])
  @@index([name])
  @@index([isFeatured])
}

enum ProductStatus {
  DRAFT           // vendor saved but not submitted
  PENDING_REVIEW  // submitted, awaiting admin approval
  ACTIVE          // approved and visible in marketplace
  REJECTED        // admin rejected — vendor can edit and resubmit
  ARCHIVED        // vendor manually unlisted
}

model Review {
  id         String   @id @default(uuid())
  productId  Int
  userId     String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isApproved Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([isApproved])
}

model Vendor {
  id            Int       @id @default(autoincrement())

  // ── Identity / ownership ──────────────────────────────────
  userId        String?   @unique
  name          String
  // NOTE: @default("") lets Prisma generate the column without
  // crashing on existing rows. After the migration runs
  // successfully, remove @default("") and run
  // `prisma migrate dev --name remove_slug_default`
  // By then all rows will have real slugs from the backfill SQL.
  slug          String    @unique @default("")

  // ── Profile ───────────────────────────────────────────────
  tagline       String?
  description   String?
  website       String?
  logo          String?
  coverImage    String?
  location      String?
  phone         String?

  // ── Social links ──────────────────────────────────────────
  twitterUrl    String?
  instagramUrl  String?
  facebookUrl   String?
  linkedinUrl   String?

  // ── Status & moderation ───────────────────────────────────
  status        VendorStatus  @default(ACTIVE)
  isVerified    Boolean       @default(false)
  verifiedAt    DateTime?
  suspendedAt   DateTime?
  suspendReason String?

  // ── Metadata ──────────────────────────────────────────────
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Relations ─────────────────────────────────────────────
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  products      Product[]
  application   VendorApplication?
  analytics     VendorAnalytics[]

  @@unique([name, website])
  @@index([slug])
  @@index([status])
  @@index([userId])
  @@index([name])
}

enum VendorStatus {
  PENDING     // applied, awaiting admin approval
  ACTIVE      // approved and live
  SUSPENDED   // temporarily disabled by admin
  REJECTED    // application rejected
}

model VendorApplication {
  id              Int                   @id @default(autoincrement())
  userId          String                @unique
  vendorId        Int?                  @unique   // set once vendor record is created

  // Application form data
  businessName    String
  slug            String                          // desired slug — admin can edit before approval
  tagline         String?
  description     String?
  website         String?
  logo            String?
  coverImage      String?
  location        String?
  phone           String?
  twitterUrl      String?
  instagramUrl    String?
  facebookUrl     String?
  linkedinUrl     String?

  // What they plan to sell — helps admin review
  productCategories  String[]                     // e.g. ["Equipment", "Software"]
  businessTypes      String[]                     // business slugs they'll serve, e.g. ["car-wash"]
  pitchNote          String?                      // "Why do you want to be a vendor on Hustlecare?"

  // Status tracking
  status          ApplicationStatus     @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?               // admin userId
  reviewNote      String?               // admin's note to applicant

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model RequirementSuggestion {
  id              Int                   @id @default(autoincrement())
  suggestedById   String                // User.id
  suggestedByRole String                // "vendor" | "user" — snapshot at time of suggestion

  // Proposed template data
  name            String
  description     String?
  category        String
  necessity       String                @default("Required")  // "Required" | "Optional"
  image           String?

  // Context: which business(es) this is relevant for
  businessIds     Int[]                 // suggested Business.id values

  // Admin review
  status          SuggestionStatus      @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?               // admin userId
  reviewNote      String?
  createdTemplateId Int?                // set when admin approves and creates the template

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  suggestedBy     User                  @relation(fields: [suggestedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([suggestedById])
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model VendorAnalytics {
  id              Int       @id @default(autoincrement())
  vendorId        Int
  date            DateTime  @db.Date  // one row per vendor per day
  profileViews    Int       @default(0)
  productClicks   Int       @default(0)
  cartAdds        Int       @default(0)

  vendor          Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, date])
  @@index([vendorId])
  @@index([date])
}



model SearchLog {
  id          String    @id @default(uuid())
  keyword     String
  location    String?
  userId      String?
  businessId  Int?
  ipAddress   String?
  userAgent   String?
  resultCount Int?
  createdAt   DateTime  @default(now())
  business    Business? @relation(fields: [businessId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([keyword])
  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model SharedBusiness {
  id          Int                    @id @default(autoincrement())
  userId      String
  businessId  Int
  name        String
  description String?
  isActive    Boolean                @default(true)
  viewCount   Int                    @default(0)
  copyCount   Int                    @default(0)
  isFeatured  Boolean                @default(false)
  featuredAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  copies      BusinessCopyActivity[]
  business    Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([isActive, viewCount])
  @@index([isActive, copyCount])
  @@index([isActive, createdAt])
  @@index([isFeatured])
}

model BusinessCopyActivity {
  id               Int            @id @default(autoincrement())
  sharedBusinessId Int
  copiedByUserId   String
  copiedAt         DateTime       @default(now())
  copiedByUser     User           @relation(fields: [copiedByUserId], references: [id], onDelete: Cascade)
  sharedBusiness   SharedBusiness @relation(fields: [sharedBusinessId], references: [id], onDelete: Cascade)

  @@index([sharedBusinessId])
  @@index([copiedByUserId])
  @@index([copiedAt])
}

model Redirect {
  id          Int      @id @default(autoincrement())
  source      String   @unique
  destination String
  permanent   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
