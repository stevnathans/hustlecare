generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  password               String?
  role                   String                  @default("user")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          DateTime?
  image                  String?
  phone                  String?
  emailNotifications     Boolean                 @default(true)
  marketingEmails        Boolean                 @default(true)
  pushNotifications      Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  lastLoginAt            DateTime?
  isVerified             Boolean                 @default(false)
  verifiedAt             DateTime?
  accounts               Account[]
  auditLogs              AuditLog[]
  businesses             Business[]
  copiedBusinesses       BusinessCopyActivity[]
  carts                  Cart[]
  comments               Comment[]
  requirementSuggestions RequirementSuggestion[]
  reviews                Review[]
  searches               SearchLog[]
  sessions               Session[]
  sharedBusinesses       SharedBusiness[]
  vendorProfile          Vendor?
  vendorApplication      VendorApplication?

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cart {
  id         String     @id @default(uuid())
  userId     String
  businessId Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  name       String?
  totalCost  Float?
  business   Business   @relation(fields: [businessId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model CartItem {
  id              String   @id @default(uuid())
  productId       Int
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  cartId          String
  unitPrice       Float
  updatedAt       DateTime @updatedAt
  category        String?  @default("Uncategorized")
  requirementName String?  @default("Unspecified Requirement")
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

model Business {
  id               Int                   @id @default(autoincrement())
  name             String
  description      String?
  image            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  slug             String                @unique
  userId           String?
  published        Boolean               @default(true)
  categoryId       Int?
  bestLocations    String[]
  costMax          Int?
  costMin          Int?
  profitPotential  String?
  skillLevel       String?
  timeToLaunchMax  Int?
  timeToLaunchMin  Int?
  category         BusinessCategory?     @relation(fields: [categoryId], references: [id])
  user             User?                 @relation(fields: [userId], references: [id])
  faqs             BusinessFaq[]
  requirements     BusinessRequirement[]
  carts            Cart[]
  howToGuide       HowToGuide?
  searches         SearchLog[]
  sharedBusinesses SharedBusiness[]

  @@index([name])
  @@index([slug])
  @@index([published])
}

model BusinessFaq {
  id           Int      @id @default(autoincrement())
  businessId   Int
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([isActive])
}

model BusinessCategory {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  slug       String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  businesses Business[]

  @@index([name])
  @@index([slug])
}

model RequirementTemplate {
  id           Int                   @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  category     String
  necessity    String
  isDeprecated Boolean               @default(false)
  deprecatedAt DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  isGlobal     Boolean               @default(false)
  businesses   BusinessRequirement[]
  products     Product[]

  @@index([category])
  @@index([necessity])
  @@index([isDeprecated])
  @@index([name])
}

model BusinessRequirement {
  id                  Int                 @id @default(autoincrement())
  businessId          Int
  templateId          Int
  descriptionOverride String?
  isActive            Boolean             @default(true)
  displayOrder        Int                 @default(0)
  source              String              @default("admin")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  necessityOverride   String?
  business            Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template            RequirementTemplate @relation(fields: [templateId], references: [id])
  comments            Comment[]

  @@unique([businessId, templateId])
  @@index([businessId])
  @@index([templateId])
  @@index([isActive])
}

model Comment {
  id                    Int                 @id @default(autoincrement())
  content               String
  userId                String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  isApproved            Boolean             @default(false)
  businessRequirementId Int
  businessRequirement   BusinessRequirement @relation(fields: [businessRequirementId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessRequirementId])
  @@index([userId])
  @@index([isApproved])
}

model Product {
  id           Int                  @id @default(autoincrement())
  name         String
  description  String?
  price        Float?
  image        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  vendorId     Int?
  url          String?
  templateId   Int?
  rejectedAt   DateTime?
  rejectReason String?
  publishedAt  DateTime?
  sku          String?
  stock        Int?
  priceMin     Float?
  priceMax     Float?
  currency     String?              @default("KES")
  isFeatured   Boolean              @default(false)
  featuredAt   DateTime?
  businessTags Int[]
  status       ProductStatus        @default(PENDING_REVIEW)
  cartItems    CartItem[]
  template     RequirementTemplate? @relation(fields: [templateId], references: [id])
  vendor       Vendor?              @relation(fields: [vendorId], references: [id])
  reviews      Review[]

  @@index([vendorId])
  @@index([templateId])
  @@index([status])
  @@index([name])
  @@index([isFeatured])
}

model Review {
  id         String   @id @default(uuid())
  productId  Int
  userId     String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isApproved Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([isApproved])
}

model Vendor {
  id                Int                @id @default(autoincrement())
  name              String
  website           String?
  logo              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  slug              String             @unique @default("")
  userId            String?            @unique
  tagline           String?
  description       String?
  coverImage        String?
  location          String?
  phone             String?
  twitterUrl        String?
  instagramUrl      String?
  facebookUrl       String?
  linkedinUrl       String?
  isVerified        Boolean            @default(false)
  verifiedAt        DateTime?
  suspendedAt       DateTime?
  suspendReason     String?
  status            VendorStatus       @default(ACTIVE)
  appealMessage     String?
  appealRespondedAt DateTime?
  appealResponse    String?
  appealStatus      AppealStatus       @default(NONE)
  appealedAt        DateTime?
  issueResolved     Boolean            @default(false)
  products          Product[]
  user              User?              @relation(fields: [userId], references: [id])
  analytics         VendorAnalytics[]
  application       VendorApplication?

  @@unique([name, website])
  @@index([slug])
  @@index([status])
  @@index([userId])
  @@index([name])
}

model VendorApplication {
  id                Int               @id @default(autoincrement())
  userId            String            @unique
  vendorId          Int?              @unique
  businessName      String
  slug              String
  tagline           String?
  description       String?
  website           String?
  logo              String?
  coverImage        String?
  location          String?
  phone             String?
  twitterUrl        String?
  instagramUrl      String?
  facebookUrl       String?
  linkedinUrl       String?
  productCategories String[]
  businessTypes     String[]
  pitchNote         String?
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewNote        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  status            ApplicationStatus @default(PENDING)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor            Vendor?           @relation(fields: [vendorId], references: [id])

  @@index([status])
  @@index([userId])
}

model RequirementSuggestion {
  id                Int              @id @default(autoincrement())
  suggestedById     String
  suggestedByRole   String
  name              String
  description       String?
  category          String
  necessity         String           @default("Required")
  image             String?
  businessIds       Int[]
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewNote        String?
  createdTemplateId Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  status            SuggestionStatus @default(PENDING)
  suggestedBy       User             @relation(fields: [suggestedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([suggestedById])
}

model VendorAnalytics {
  id            Int      @id @default(autoincrement())
  vendorId      Int
  date          DateTime @db.Date
  profileViews  Int      @default(0)
  productClicks Int      @default(0)
  cartAdds      Int      @default(0)
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, date])
  @@index([vendorId])
  @@index([date])
}

model SearchLog {
  id          String    @id @default(uuid())
  keyword     String
  location    String?
  userId      String?
  businessId  Int?
  ipAddress   String?
  userAgent   String?
  resultCount Int?
  createdAt   DateTime  @default(now())
  business    Business? @relation(fields: [businessId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([keyword])
  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model SharedBusiness {
  id          Int                    @id @default(autoincrement())
  userId      String
  businessId  Int
  name        String
  description String?
  isActive    Boolean                @default(true)
  viewCount   Int                    @default(0)
  copyCount   Int                    @default(0)
  isFeatured  Boolean                @default(false)
  featuredAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  copies      BusinessCopyActivity[]
  business    Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([isActive, viewCount])
  @@index([isActive, copyCount])
  @@index([isActive, createdAt])
  @@index([isFeatured])
}

model BusinessCopyActivity {
  id               Int            @id @default(autoincrement())
  sharedBusinessId Int
  copiedByUserId   String
  copiedAt         DateTime       @default(now())
  copiedByUser     User           @relation(fields: [copiedByUserId], references: [id], onDelete: Cascade)
  sharedBusiness   SharedBusiness @relation(fields: [sharedBusinessId], references: [id], onDelete: Cascade)

  @@index([sharedBusinessId])
  @@index([copiedByUserId])
  @@index([copiedAt])
}

model Redirect {
  id          Int      @id @default(autoincrement())
  source      String   @unique
  destination String
  permanent   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HowToGuide {
  id              Int              @id @default(autoincrement())
  businessId      Int              @unique
  intro           String?
  isPublished     Boolean          @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  imageUrl        String?
  title           String?
  faqs            HowToFaq[]
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  references      HowToReference[]
  sections        HowToSection[]
  steps           HowToStep[]

  @@index([businessId])
  @@index([isPublished])
}

model HowToStep {
  id           Int        @id @default(autoincrement())
  guideId      Int
  title        String
  description  String
  imageUrl     String?
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  guide        HowToGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([displayOrder])
}

model HowToSection {
  id           Int              @id @default(autoincrement())
  guideId      Int
  type         HowToSectionType @default(TIPS)
  title        String
  content      String
  imageUrl     String?
  displayOrder Int              @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  guide        HowToGuide       @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([displayOrder])
}

model HowToFaq {
  id           Int        @id @default(autoincrement())
  guideId      Int
  question     String
  answer       String
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  guide        HowToGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

model HowToReference {
  id        Int        @id @default(autoincrement())
  guideId   Int
  refNumber Int
  title     String
  url       String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  guide     HowToGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, refNumber])
  @@index([guideId])
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  ARCHIVED
}

enum AppealStatus {
  NONE
  PENDING
  REJECTED
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HowToSectionType {
  TIPS
  WARNING
  NOTE
  INFO
  CONCLUSION
}
